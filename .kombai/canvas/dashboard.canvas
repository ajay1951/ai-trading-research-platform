y-2 text-sm text-white/60 hover:bg-white/5 hover:text-white transition-all\" data-kid=\"45\">\n                        <i class=\"ti ti-settings\" data-kid=\"46\"></i> Configuration\n                    </a>\n                </div>\n            </div>\n        </nav>\n\n        <div class=\"mt-auto border-t border-white/10 pt-6 px-2\" data-kid=\"47\">\n            <div class=\"flex items-center gap-3 p-2 rounded-xl bg-white/[0.02] border border-white/5\" data-kid=\"48\">\n                <img src=\"https://i.pravatar.cc/150?u=trader1\" class=\"h-8 w-8 rounded-full border border-white/20\" alt=\"Avatar\" data-kid=\"49\">\n                <div class=\"flex-1 overflow-hidden\" data-kid=\"50\">\n                    <p class=\"truncate text-[11px] font-bold text-white\" data-kid=\"51\">Inst. Desk #04</p>\n                    <div class=\"flex items-center gap-1\" data-kid=\"52\">\n                        <div class=\"h-1 w-1 rounded-full bg-[#00FF40]\" data-kid=\"53\"></div>\n                        <p class=\"text-[9px] font-bold text-white/30 uppercase tracking-wider\" data-kid=\"54\">Tier 1 Access</p>\n                    </div>\n                </div>\n                <i class=\"ti ti-logout text-white/30 hover:text-[#FF0800] transition-colors cursor-pointer text-sm\" data-kid=\"55\"></i>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 relative z-10\" data-kid=\"56\">\n        \n        <header class=\"sticky top-0 z-50 h-20 px-8 flex items-center justify-between border-b border-white/10 bg-[#010B13]/40 backdrop-blur-xl\" data-kid=\"57\">\n            <div class=\"flex items-center gap-4 flex-1 max-w-xl\" data-kid=\"58\">\n                <div class=\"relative w-full\" data-kid=\"59\">\n                    <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg\" data-kid=\"60\"></i>\n                    <input type=\"text\" placeholder=\"Search asset (BTC/USDT, ETH/USD, AAPL...)\" class=\"w-full h-12