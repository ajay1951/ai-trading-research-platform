data-kid=\"121\">\n                                <span class=\"text-2xl font-black font-['Inter'] text-white\" data-kid=\"122\">2.81<span class=\"text-sm font-medium text-white/40\" data-kid=\"123\">%</span></span>\n                                <span class=\"text-[10px] font-bold text-[#00FF40]\" data-kid=\"124\">+0.12%</span>\n                            </div>\n                        </div>\n                        <div class=\"bg-white/5 rounded-2xl p-4 border border-white/5\" data-kid=\"125\">\n                            <p class=\"text-[10px] font-bold text-white/30 uppercase mb-1\" data-kid=\"126\">Leverage Cap</p>\n                            <div class=\"flex items-baseline gap-2\" data-kid=\"127\">\n                                <span class=\"text-2xl font-black font-['Inter'] text-white\" data-kid=\"128\">10<span class=\"text-sm font-medium text-white/40\" data-kid=\"129\">x</span></span>\n                                <span class=\"text-[10px] font-bold text-white/40\" data-kid=\"130\">Stable</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3 pt-6 border-t border-white/10\" data-kid=\"131\">\n                        <div class=\"flex items-center justify-between p-3 rounded-2xl bg-white/[0.02] border border-white/5\" data-kid=\"132\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"133\">\n                                <div class=\"flex h-8 w-8 items-center justify-center rounded-lg bg-[#FF0800]/10 text-[#FF0800]\" data-kid=\"134\">\n                                    <i class=\"ti ti-trending-down text-sm\" data-kid=\"135\"></i>\n                                </div>\n                                <span class=\"text-[10px] font-black text-white/30 uppercase tracking-widest\" data-kid=\"136\">Stop Loss</span>\n                            </div>\n                            <span class=\"text-sm font-bold font-mono