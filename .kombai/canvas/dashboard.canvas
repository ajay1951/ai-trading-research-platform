      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=DM+Sans:wght@400;500;700&family=Fira+Code:wght@400;500&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-bg: #010B13;\n        --color-panel: #1A1A24;\n        --color-green: #00FF40;\n        --color-red: #FF0800;\n        --color-blue: #00d4ff;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #e0e0e0;\n        font-family: 'DM Sans', sans-serif;\n        margin: 0;\n        overflow-x: hidden;\n    }\n\n    .glass {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(20px);\n        -webkit-backdrop-filter: blur(20px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);\n    }\n\n    .neon-text-green {\n        color: var(--color-green);\n        text-shadow: 0 0 20px rgba(0, 255, 64, 0.4), 0 0 40px rgba(0, 255, 64, 0.1), 0 0 60px rgba(0, 255, 64, 0.05);\n    }\n\n    .neon-text-red {\n        color: var(--color-red);\n        text-shadow: 0 0 20px rgba(255, 8, 0, 0.4), 0 0 40px rgba(255, 8, 0, 0.1);\n    }\n\n    .scanline {\n        background: linear-gradient(to bottom, transparent 50%, rgba(0, 255, 64, 0.02) 50%);\n        background-size: 100% 4px;\n        pointer-events: none;\n    }\n\n    .glow-circle {\n        position: absolute;\n        border-radius: 50%;\n        filter: blur(100px);\n        z-index: 0;\n        opacity: 0.15;\n    }\n\n    .terminal-cursor {\n        display: inline-block;\n        width: 8px;\n        height: 15px;\n        background-color: var(--color-green);\n        animation: blink 1s step-end infinite;\n        vertical-align: middle;\n        margin-left: 4px;\n    }\n\n    @keyframes blink {\n        from, to { opacity: 1; }\n        50% { opacity: 0; }\n    }\n\n    /* Custom scrollbar */\n    ::-webkit-scrollbar {\n        width: 5px;\n        height: 5px;\n    }\n    ::-webkit-scrollbar-track {\n        background: rgba(0,0,0,0.2);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: rgba(255,255,255,0.1);\n        border-radius: 10px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n        background: rgba(255,255,255,0.2);\n    }\n</style>\n\n<div class=\"flex min-h-[1200px] w-full bg-[#010B13] relative overflow-hidden\" data-kid=\"1\">\n    \n    <div class=\"glow-circle w-[600px] h-[600px] bg-[#00FF40] -top-48 -left-48\" data-kid=\"2\"></div>\n    <div class=\"glow-circle w-[500px] h-[500px] bg-[#00d4ff] bottom-0 -right-24\" data-kid=\"3\"></div>\n\n    \n    <aside class=\"sticky top-0 h-[1200px] w-[300px] border-r border-white/10 bg-[#010B13]/80 backdrop-blur-md p-6 flex flex-col z-10\" data-kid=\"4\">\n        <div class=\"mb-10 flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#00FF40] to-[#00d4ff] shadow-[0_0_20px_rgba(0,255,64,0.3)]\" data-kid=\"6\">\n                <i class=\"ti ti-bolt text-2xl text-black\" data-kid=\"7\"></i>\n            </div>\n            <h1 class=\"font-['Inter'] text-xl font-black tracking-tighter text-white\" data-kid=\"8\">SENTINEL <span class=\"text-[#00FF40]\" data-kid=\"9\">AI</span></h1>\n        </div>\n\n        <nav class=\"flex-1 space-y-6\" data-kid=\"10\">\n            <div data-kid=\"11\">\n                <h2 class=\"mb-4 text-[10px] font-bold tracking-[0.2em] text-white/30 uppercase\" data-kid=\"12\">Active Agents</h2>\n                <div class=\"space-y-2\" data-kid=\"13\">\n                    \n                    <div class=\"flex items-center gap-3 rounded-xl p-3 border border-white/5 bg-white/[0.02] hover:bg-white/[0.08] hover:border-white/10 transition-all duration-300 cursor-pointer group\" data-kid=\"14\">\n                        <div class=\"flex h-10 w-10 items-center just