-center gap-1.5\" data-kid=\"166\"><span class=\"text-white/30 font-bold\" data-kid=\"167\">O</span> <span class=\"text-white font-semibold\" data-kid=\"168\">67,120.50</span></div>\n                            <div class=\"text-[10px] font-mono flex items-center gap-1.5\" data-kid=\"169\"><span class=\"text-white/30 font-bold\" data-kid=\"170\">H</span> <span class=\"text-[#00FF40] font-semibold\" data-kid=\"171\">68,450.00</span></div>\n                            <div class=\"text-[10px] font-mono flex items-center gap-1.5\" data-kid=\"172\"><span class=\"text-white/30 font-bold\" data-kid=\"173\">L</span> <span class=\"text-[#FF0800] font-semibold\" data-kid=\"174\">66,980.20</span></div>\n                            <div class=\"text-[10px] font-mono flex items-center gap-1.5\" data-kid=\"175\"><span class=\"text-white/30 font-bold\" data-kid=\"176\">C</span> <span class=\"text-white font-semibold\" data-kid=\"177\">68,234.10</span></div>\n                            <div class=\"h-3 w-px bg-white/10\" data-kid=\"178\"></div>\n                            <div class=\"text-[10px] font-mono flex items-center gap-1.5\" data-kid=\"179\"><span class=\"text-[#00d4ff]/40 font-bold italic\" data-kid=\"180\">EMA 20</span> <span class=\"text-[#00d4ff] font-semibold\" data-kid=\"181\">66,540</span></div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative h-[100px] w-full border-t border-white/5 pt-4\" data-kid=\"182\">\n                        <canvas id=\"rsiChart\" data-kid=\"183\"></canvas>\n                        <div class=\"absolute top-4 left-4 z-10 pointer-events-none\" data-kid=\"184\">\n                            <div class=\"text-[10px] font-mono text-white/40\" data-kid=\"185\">RSI(14): <span class=\"text-white\" data-kid=\"186\">64.28</span></div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative h-[120px] w-full border-t border-white/5 pt-4\" data-kid=\"187\">\n                        <canvas id=\"macdChart\" data-kid=\"188\"></canvas>\n                        <div class=\"absolute top-4 left-4 z-10 pointer-events-none\" data-kid=\"189\">\n                            <div class=\"text-[10px] font-mono text-white/40\" data-kid=\"190\">MACD(12,26,9): <span class=\"text-white\" data-kid=\"191\">420.50</span> <span class=\"text-[#00FF40]\" data-kid=\"192\">210.30</span></div>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n            \n            <section class=\"rounded-[24px] border border-white/10 bg-[#010B13]/60 backdrop-blur-xl overflow-hidden font-['Fira_Code'] relative\" data-kid=\"193\">\n                <div class=\"absolute inset-0 scanline opacity-20 pointer-events-none\" data-kid=\"194\"></div>\n                <div class=\"flex items-center justify-between bg-white/5 px-6 py-4 border-b border-white/10 relative z-10\" data-kid=\"195\">\n                    <div class=\"flex gap-2\" data-kid=\"196\">\n                        <div class=\"h-3 w-3 rounded-full bg-[#FF5F56]\" data-kid=\"197\"></div>\n                        <div class=\"h-3 w-3 rounded-full bg-[#FFBD2E]\" data-kid=\"198\"></div>\n                        <div class=\"h-3 w-3 rounded-full bg-[#27C93F]\" data-kid=\"199\"></div>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"200\">\n                        <i class=\"ti ti-terminal text-[#00FF40] text-sm\" data-kid=\"201\"></i>\n                        <span class=\"text-[10px] font-bold tracking-[0.2em] text-white/30 uppercase\" data-kid=\"202\">SENTINEL_AI_LOGS_V2.4</span>\n                    </div>\n                    <div class=\"flex items-center gap-3\" data-kid=\"203\">\n                        <span class=\"text-[10px] text-white/20\" data-kid=\"204\">SYSTEM: STABLE</span>\n                        <i class=\"ti ti-download text-white/20 hover:text-white cursor-pointer\" data-kid=\"205\"></i>\n                    </div>\n                </div>\n                <div class=\"h-64 p-6 overflow-y-auto text-xs leading-relaxed scrollbar-hide\" data-kid=\"206\">\n                    <div class=\"space-y-1.5\" data-kid=\"207\">\n                        <p data-kid=\"208\"><span class=\"text-white/20\" data-kid=\"209\">[2024-05-24 14:32:01]</span> <span class=\"text-[#00d4ff]\" data-kid=\"210\">INFO:</span> System initializing. Loading memory from distributed nodes...</p>\n                        <p data-kid=\"211\"><span class=\"text-white/20\" data-kid=\"212\">[2024-05-24 14:32:02]</span> <span class=\"text-[#00d4ff]\" data-kid=\"213\">INFO:</span> Quant-Agent calculating Bollinger Band expansion for <span class=\"text-white\" data-kid=\"214\">BTC/USDT</span>.</p>\n                        <p data-kid=\"215\"><span class=\"text-white/20\" data-kid=\"216\">[2024-05-24 14:32:03]</span> <span class=\"text-[#00FF40]\" data-kid=\"217\">SUCCESS:</span> Support confirmed at $65,400. Bullish RSI divergence confirmed (14-period).</p>\n                        <p data-kid=\"218\"><span class=\"text-white/20\" data-kid=\"219\">[2024-05-24 14:32:05]</span> <span class=\"text-amber-400\" data-kid=\"220\">WARN:</span> High volatility spike detected in order book depth. Adjusting VaR models in real-time.</p>\n                        <p data-kid=\"221\"><span class=\"text-white/20\" data-kid=\"222\">[2024-05-24 14:32:06]</span> <span class=\"text-[#00d4ff]\" data-kid=\"223\">EXEC:</span> Dispatching alpha signal to execution engine. Target confidence threshold met.</p>\n                        <p data-kid=\"224\"><span class=\"text-white/20\" data-kid=\"225\">[2024-05-24 14:32:08]</span> <span class=\"text-[#00d4ff]\" data-kid=\"226\">INFO:</span> Monitoring Research feeds... SEC ETF inflows tracking +$420M today.</p>\n                        <p data-kid=\"227\"><span class=\"text-white/20\" data-kid=\"228\">[2024-05-24 14:32:10]</span> <span class=\"text-[#00FF40]\" data-kid=\"229\">SUCCESS:</span> Risk Oracle re-balanced Stop-Loss targets to $64,432 based on new volatility data.</p>\n                        <p class=\"pt-2\" data-kid=\"230\"><span class=\"text-white/20\" data-kid=\"231\">[2024-05-24 14:32:12]</span> Sentinel-AI: Awaiting next market event or user query <span class=\"terminal-cursor\" data-kid=\"232\"></span></p>\n                    </div>\n                </div>\n            </section>\n        </div>\n    </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"233\"></script>\n<script data-kid=\"234\">\n    document.addEventListener('DOMContentLoaded', () => {\n        const createChart = (id, type, data, options) => {\n            const ctx = document.getElementById(id).getContext('2d');\n            return new Chart(ctx, {\n                type: type,\n                data: data,\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: { legend: { display: false } },\n                    scales: {\n                        x: { display: false },\n                        y: { \n                            display: true, \n                            grid: { color: 'rgba(255,255,255,0.02)' },\n                            ticks: { color: 'rgba(255,255,255,0.15)', font: { size: 9, family: 'Fira Code' } }\n                        }\n                    },\n                    ...options\n                }\n            });\n        };\n\n        // Main Chart (Price & Volume overlay mock)\n        createChart('mainChart', 'line', {\n            labels: Array.from({length: 50}, (_, i) => i),\n            datasets: [{\n                label: 'Price',\n                data: Array.from({length: 50}, () => 65000 + Math.random() * 5000),\n                borderColor: '#00d4ff',\n                borderWidth: 2,\n                tension: 0.1,\n                pointRadius: 0,\n                fill: true,\n                backgroundColor: (context) => {\n                    const chart = context.chart;\n                    const {ctx, chartArea} = chart;\n                    if (!chartArea) return null;\n                    const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n                    gradient.addColorStop(0, 'rgba(0, 212, 255, 0.1)');\n                    gradient.addColorStop(1, 'rgba(0, 212, 255, 0)');\n                    return gradient;\n                }\n            }]\n        }, {\n            scales: {\n                x: { display: false },\n                y: { \n                    position: 'right',\n                    grid: { color: 'rgba(255,255,255,0.02)' },\n                    ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: 'Fira Code' } }\n                }\n            }\n        });\n\n        // RSI Chart\n        createChart('rsiChart', 'line', {\n            labels: Array.from({length: 50}, (_, i) => i),\n            datasets: [{\n                data: Array.from({length: 50}, () => 30 + Math.random() * 40),\n                borderColor: '#ffaa00',\n                borderWidth: 1.5,\n                pointRadius: 0,\n                tension: 0.1\n            }]\n        }, {\n            scales: {\n                y: { \n                    min: 0, max: 100, \n                    position: 'right',\n                    grid: { color: 'rgba(255,255,255,0.02)' },\n                    ticks: { \n                        color: 'rgba(255,255,255,0.15)', \n                        font: { size: 9 },\n                        stepSize: 30,\n                        callback: (value) => value === 30 || value === 70 ? value : ''\n                    }\n                }\n            }\n        });\n\n        // MACD Chart\n        createChart('macdChart', 'bar', {\n            labels: Array.from({length: 50}, (_, i) => i),\n            datasets: [{\n                data: Array.from({length: 50}, () => Math.random() * 100 - 50),\n                backgroundColor: (context) => context.raw > 0 ? 'rgba(0, 255, 64, 0.4)' : 'rgba(255, 8, 0, 0.4)',\n                borderRadius: 2\n            }]\n        }, {\n            scales: {\n                y: { \n                    position: 'right',\n                    grid: { color: 'rgba(255,255,255,0.02)' },\n                    ticks: { color: 'rgba(255,255,255,0.15)', font: { size: 9 } }\n                }\n            }\n        });\n    });\n</script>",
