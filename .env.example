# =======================================================
# Multi-Agent Financial Intelligence System
# Environment Configuration Template
# =======================================================

# -------------------------------------------------------
# LLM Providers
# -------------------------------------------------------
# OpenRouter API Key (required for Slow Lane background agents)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -------------------------------------------------------
# High-Frequency Data & Execution (WebSocket CCXT.pro)
# -------------------------------------------------------
# Generic Exchange credentials for live WebSocket order routing
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_SECRET_KEY=your_exchange_secret_key_here

# Binance specific fallbacks (optional)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# -------------------------------------------------------
# Historical High-Resolution Data Providers (Backtesting)
# -------------------------------------------------------
# Used for fetching granular tick/OHLCV data for Stat Arb models
POLYGON_API_KEY=your_polygon_api_key_here
DATABENTO_API_KEY=your_databento_api_key_here

# -------------------------------------------------------
# Storage & Memory Backends
# -------------------------------------------------------
# Toggle database usage
USE_REDIS=false
USE_CHROMADB=false
USE_INFLUXDB=false

# Redis (Pub/Sub and Fast Lane SharedMemory caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ChromaDB (Vector database for local FinBERT embeddings)
CHROMADB_PERSIST_DIR=./chroma_db

# InfluxDB (Time-series storage for raw tick data)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=financial_ai
INFLUXDB_BUCKET=market_data

# -------------------------------------------------------
# Web & Dashboard Configuration
# -------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# SRE Heartbeat: External uptime monitor (e.g., BetterUptime, Healthchecks.io)
# The dashboard sends an HTTP GET here every 30s as long as the trading loop is active.
UPTIME_PING_URL=https://hc-ping.com/your-uuid-here

# -------------------------------------------------------
# External Information APIs
# -------------------------------------------------------
# SEC EDGAR parser settings
SEC_USER_AGENT=Financial Intelligence Agent contact@example.com

# GNews API Key for more reliable alternative news fetching
GNEWS_API_KEY=your_gnews_api_key_here
